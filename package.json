{
  "name": "@seobryn/ghost-glyph",
  "version": "0.1.0",
  "description": "Hide and recover text using zero-width characters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node ./scripts/build.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "zero-width",
    "invisible-text",
    "steganography",
    "typescript"
  ],
  "author": "Seobryn <ing.jose.joya@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/seobryn/ghost-glyph.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}